{
  "name": "edoxen-js",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for edoxen JS packages: data layer, Astro components, Vue adapter.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "docs",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "gen:types": "pnpm -F edoxen gen:types",
    "sync:schema": "pnpm -F edoxen sync:schema",
    "check:budget": "pnpm -F edoxen build && node scripts/check-bundle-budget.mjs",
    "check:schema-sync": "node scripts/check-schema-sync.mjs",
    "check:pack": "pnpm -r --filter='./packages/*' build && node scripts/check-pack.mjs",
    "check:all": "pnpm check:schema-sync && pnpm check:budget && pnpm check:pack && pnpm -r test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "dependencies": {
    "@types/node": "^26.1.0"
  }
}
