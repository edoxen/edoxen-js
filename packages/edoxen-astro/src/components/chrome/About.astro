---
// Default About page.
//
// A consumer can override this in two ways:
//
// 1. Drop a markdown file at `src/pages/about.md` — Astro will route
//    it to `/about` automatically and ignore this default.
//
// 2. Set `siteConfig.aboutContent` (a markdown string) in
//    `edoxen.config.ts` — this component renders that content instead
//    of the bundled default.
//
// Both paths leave the rest of the chrome (header/footer) untouched.

import type { SiteConfig } from '../../config/index.js'
import { defaultSiteConfig } from '../../config/index.js'
import { loadSiteConfig } from '../../config/index.js'

interface Props {
  /** Override the config used to render this page. */
  config?: SiteConfig
}

const cfg = Astro.props.config ?? (await loadSiteConfig())

const defaultContent = `## About this site

This site is an **Edoxen-powered** registry of meetings and
decisions for **${cfg.title}**.

[Edoxen](https://github.com/edoxen/edoxen) is an open-source
information model for formal proceedings — published records of any
deliberative body: meetings, agendas, minutes, attendance rolls,
votes, motions, and the decisions they adopt, in any language and
script per ISO 24229.

The data on this site is stored as plain YAML files that conform to
the [Edoxen Model 1.0](https://github.com/edoxen/edoxen-model). The
browsable interface is generated by
[\`@edoxen/astro\`](https://github.com/edoxen/edoxen-js).

### Source data

Every page on this site has a 'View source YAML' link that points at
the underlying data file. Corrections and additions are welcome via
the project's source repository.
`

const content = cfg.aboutContent ?? defaultContent
---

<article class="edoxen-about">
  <h1>About</h1>
  <div class="edoxen-about__content" set:html={content} />
</article>

<style>
  .edoxen-about {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    color: var(--edoxen-text, #0f172a);
    font-family: var(--edoxen-font-body, system-ui, sans-serif);
    line-height: 1.7;
  }
  :global(.dark) .edoxen-about { color: var(--edoxen-text, #f1f5f9); }
  .edoxen-about h1 {
    font-family: var(--edoxen-font-display, Georgia, serif);
    font-size: 2.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }
  .edoxen-about__content :global(h2) {
    font-family: var(--edoxen-font-display, Georgia, serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .edoxen-about__content :global(h3) {
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .edoxen-about__content :global(a) {
    color: var(--edoxen-brand, #0e7490);
    text-decoration: underline;
  }
  .edoxen-about__content :global(strong) { font-weight: 600; }
  .edoxen-about__content :global(code) {
    font-family: var(--edoxen-font-mono, monospace);
    background: rgba(14, 116, 144, 0.08);
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    font-size: 0.9em;
  }
</style>
