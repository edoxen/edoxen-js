---
// MeetingDetail.astro — single-meeting detail page body.
import type { MeetingViewModel } from '@edoxen/edoxen'

export interface Props {
  meeting: MeetingViewModel
}

const { meeting } = Astro.props
const dateRange = meeting.start && meeting.end
  ? `${meeting.start} → ${meeting.end}`
  : (meeting.start || meeting.end || '')
---

<article class="edoxen-meeting">
  <header class="edoxen-meeting__header">
    <h1>{meeting.title}</h1>
    <p class="edoxen-meeting__meta">
      {meeting.venue && <span>{meeting.venue}</span>}
      {dateRange && <span>· {dateRange}</span>}
      {meeting.committee && <span>· {meeting.committee}</span>}
    </p>
  </header>
  <slot />
</article>

<style>
.edoxen-meeting__header h1 { margin: 0 0 0.5rem; font-size: 1.5rem; }
.edoxen-meeting__meta { color: #6b7280; font-size: 0.9rem; margin: 0; }
.edoxen-meeting__meta span { margin-right: 0.5rem; }
</style>
